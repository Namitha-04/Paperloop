# Copy this file to .env and fill in real values. Never commit .env to GitHub.

# Get this from Supabase: Project Settings -> Database -> Connection string -> URI
# Make sure to use the "Connection pooling" string if available, port 6543
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Any long random string works. Generate one with: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_long_random_string

PORT=4000
